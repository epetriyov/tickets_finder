# Скопируй в .env и заполни первые две строки
TELEGRAM_BOT_TOKEN=123456789:AAE...твой-токен...
TELEGRAM_CHAT_ID=123456789

# Ссылка на страницу СОБЫТИЯ на afisha.yandex.ru — единственное, что нужно
# поменять для мониторинга другого мероприятия.
TARGET_URL=https://afisha.yandex.ru/moscow/concert/basta-2026-08-29

# Дата сеанса по МСК (YYYY-MM-DD). Обязательна, если у события несколько дат
# (иначе бот перечислит найденные даты и попросит выбрать).
SESSION_DATE=2026-08-29

# Ключ сеанса. Пусто = определить автоматически по TARGET_URL + SESSION_DATE
# (рекомендуется). Можно задать вручную, если автоопределение сломается.
SESSION_KEY=

# Название события в сообщениях. Пусто = взять со страницы события.
EVENT_NAME=

# clientKey официального виджета (если API начнёт отвечать ошибкой — см. README)
CLIENT_KEY=f6dc63f9-18ab-471b-89ff-eb9773910840

# Как часто опрашивать API, секунд (реальный интервал с джиттером ±15%)
CHECK_INTERVAL_SECONDS=30

# Критерии поиска
MAX_PRICE_PER_TICKET=15000
SEATS_NEEDED=2

# Какие сектора интересуют: диапазоны/отдельные через запятую,
# например C134-C139,A109-A112 или A110. Пусто = весь зал.
SECTORS=

# 1 = не уведомлять о секторах с пометкой "(ограниченная видимость)"
IGNORE_LIMITED_VIEW=0

# Мониторинг: "я жив"-сообщение в Telegram раз в N часов (можно дробное).
# 0 или пусто = выключен (по умолчанию).
HEARTBEAT_HOURS=0
# Алерт в Telegram после N неудачных запросов к Афише подряд
# (повтор не чаще раза в час; при восстановлении придёт ✅)
ERROR_ALERT_THRESHOLD=5
